# Copy this file to ".env" (in the same "backend" folder) and fill in real values.
# ".env" is gitignored and should NEVER be committed — this file is just the template.

# Gmail account used to send FlyNow notification emails
EMAIL_USER=flynow.dev@gmail.com

# Gmail App Password — NOT your normal Gmail password.
# Generate one at https://myaccount.google.com/apppasswords
EMAIL_PASS="your-16-character-app-password"

# Stripe Secret Key
# Find your test key by signing in/making an account at https://dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_your_secret_key_here"